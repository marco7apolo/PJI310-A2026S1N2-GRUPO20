{
  "version": 2,
  "builds": [
    {
      "src": "sgo/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.14"
      }
    },
    {
      "src": "build.sh",
      "use": "@vercel/shell"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "sgo/wsgi.py"
    }
  ]
}
